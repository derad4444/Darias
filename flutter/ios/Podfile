platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
    end
  end

  # Patch FirebaseFunctions FunctionsContext.swift to fix iOS 16 Swift Concurrency crash.
  # Root cause: async let + throwing exits scope early, causing swift_task_dealloc fatalError
  # in the iOS 16 Swift runtime (SR-15609). Fixed in iOS 17+ runtime only.
  # Fix: replace async let with sequential await to avoid the buggy cleanup path.
  funcs_context = File.join(installer.sandbox.root,
    'FirebaseFunctions/FirebaseFunctions/Sources/Internal/FunctionsContext.swift')
  if File.exist?(funcs_context)
    content = File.read(funcs_context)
    if content.include?('async let authToken')
      patched = content.sub(
        /    async let authToken = auth\?\.getToken\(forcingRefresh: false\)\n    async let appCheckToken = getAppCheckToken\(options: options\)\n    async let limitedUseAppCheckToken = getLimitedUseAppCheckToken\(options: options\)\n\n    \/\/ Only `authToken` is throwing.*?\n    \/\/ from `try authToken`.*?\n    return try await FunctionsContext\(\n      authToken: authToken,\n      fcmToken: messaging\?\.fcmToken,\n      appCheckToken: appCheckToken,\n      limitedUseAppCheckToken: limitedUseAppCheckToken\n    \)/m,
        "    // Patched: sequential await instead of async let to fix iOS 16 Swift Concurrency crash.\n" \
        "    // async let + throwing exits scope early, causing swift_task_dealloc fatalError\n" \
        "    // in the iOS 16 Swift runtime (SR-15609). Fixed in iOS 17+ runtime only.\n" \
        "    let authToken = try await auth?.getToken(forcingRefresh: false)\n" \
        "    let appCheckToken = await getAppCheckToken(options: options)\n" \
        "    let limitedUseAppCheckToken = await getLimitedUseAppCheckToken(options: options)\n" \
        "    return FunctionsContext(\n" \
        "      authToken: authToken,\n" \
        "      fcmToken: messaging?.fcmToken,\n" \
        "      appCheckToken: appCheckToken,\n" \
        "      limitedUseAppCheckToken: limitedUseAppCheckToken\n" \
        "    )"
      )
      File.write(funcs_context, patched)
      puts "✅ Patched FunctionsContext.swift for iOS 16 compatibility"
    else
      puts "ℹ️ FunctionsContext.swift already patched or changed upstream"
    end
  end
end
